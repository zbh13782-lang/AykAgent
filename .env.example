# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Tavily 搜索 API (可选，用于网络搜索功能)
TAVILY_API_KEY=your_tavily_api_key_here

# 工作目录 (可选)
WORKDIR=./workspace

# ---------- 短期记忆 / Redis ----------
# 短期记忆后端：memory（进程内，默认）或 redis（持久化，多会话）
CHECKPOINTER_BACKEND=memory

# Redis 连接配置（CHECKPOINTER_BACKEND=redis 时使用）
# 若使用本仓库的 docker-compose.yml，REDIS_HOST=127.0.0.1 / REDIS_PORT=6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# 启动 docker-compose 时必填；生产请使用强随机密码
REDIS_PASSWORD=change-me-to-a-strong-password
# 也可以直接给一个完整 URL，优先级高于上面的分散变量
# REDIS_URL=redis://:password@127.0.0.1:6379/0

# 短期记忆 TTL（秒），默认 24 小时；设为 0 表示不过期
SHORT_MEMORY_TTL=86400

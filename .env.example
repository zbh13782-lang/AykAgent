# OpenAI 配置
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
OPENAI_BASE_URL=

# Tavily 搜索 API (可选，用于网络搜索功能)
TAVILY_API_KEY=

# 工作目录 (可选)
WORKDIR=./Aykagent

# ---------- Redis ----------
# 短期记忆后端：memory 或 redis
CHECKPOINTER=redis

# Redis 连接配置（CHECKPOINTER_BACKEND=redis 时使用）
# 若使用本仓库的 docker-compose.yml，REDIS_HOST=127.0.0.1 / REDIS_PORT=6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# 启动 docker-compose 时必填；生产请使用强随机密码
REDIS_PASSWORD=
# 也可以直接给一个完整 URL，优先级高于上面的分散变量
# REDIS_URL=redis://:password@127.0.0.1:6379/0

# 短期记忆 TTL（秒），默认 1 小时；设为 0 表示不过期
SHORT_MEMORY_TTL=3600

THREAD_ID=

# GitHub Remote MCP Server（可选）不想选设置为false即可
MCP_ENABLE_GITHUB=true
# 示例: https://api.githubcopilot.com/mcp/
MCP_GITHUB_URL=https://api.githubcopilot.com/mcp/
# 如服务端需要 Bearer Token，在这里配置
MCP_GITHUB_TOKEN=
# 可选：限制可暴露给 Agent 的工具名，逗号分隔
MCP_GITHUB_TOOL_ALLOWLIST=